# Node.js ASR WebSocket Proxy
FROM node:20-alpine

WORKDIR /app

# Install bun
RUN npm install -g bun

# Copy package files
COPY mini-services/asr-service/package.json ./

# Install dependencies
RUN bun install

# Copy source
COPY mini-services/asr-service/index.ts ./

# Environment
ENV NODE_ENV=production
ENV PORT=3003

EXPOSE 3003

# Run
CMD ["bun", "run", "index.ts"]
